{
  "name": "wellstudio-platform",
  "version": "0.1.0",
  "private": true,
  "description": "WellStudio modular monolith built with Next.js.",
  "packageManager": "pnpm@10.21.0",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose stop db",
    "db:logs": "docker compose logs -f db",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "check:foundation": "pnpm lint && pnpm typecheck && pnpm test:unit && pnpm build",
    "check:auth": "pnpm lint && pnpm typecheck && vitest run tests/unit/auth && pnpm build",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:auth": "playwright test tests/e2e/auth",
    "test:e2e:auth:sandbox": "playwright test tests/e2e/auth/auth-sandbox.spec.ts",
    "test:e2e:smoke": "playwright test --grep @smoke",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@prisma/client": "^7.5.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^4.0.6",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.6",
    "prisma": "^7.5.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
